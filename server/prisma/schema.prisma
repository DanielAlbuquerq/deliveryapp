generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}
datasource db {
  provider = "postgresql"
}

model Restaurant {
  id                String   @id @default(uuid())
  nome              String
  logo              String
  categoria         String
  taxaEntrega       Int      @default(0) // Armazenado em centavos [cite: 75, 76]
  raioEntregaKm     Int      @default(5)
  lat               Float
  lng               Float
  tempoEntrega      String   @default("30 min")
  ativo             Boolean  @default(true)
  pedidos           Order[]
  createdAt         DateTime @default(now())
}

enum PaymentMethod {
  DINHEIRO
  dinheiro
  CARTAO_CREDITO
  cartao_credito
  CARTAO_DEBITO
  cartao_debito
  PIX
  pix
}

model Order {
  id             String     @id @default(uuid())
  restaurante    Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId   String
  itens          Json       // Armazena a lista de produtos como JSON
  subtotal       Int
  taxaEntrega    Int        // Valor fixo capturado no momento do pedido [cite: 43, 50]
  total          Int
  status         String     @default("pendente")
  createdAt      DateTime   @default(now())
  metodoPagamento  PaymentMethod   @default(PIX)
}